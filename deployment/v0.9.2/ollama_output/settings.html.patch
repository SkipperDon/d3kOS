+
+      <script>
+      document.addEventListener('DOMContentLoaded', function() {
+        const system = Units.getPreference();
+        document.getElementById('measurement-toggle').checked = (system === 'metric');
+        document.getElementById('measurement-label').textContent =
+          system === 'metric' ? 'Metric' : 'Imperial';
+      });
+
+      function handleMeasurementToggle() {
+        const isMetric = document.getElementById('measurement-toggle').checked;
+        const system = isMetric ? 'metric' : 'imperial';
+        Units.setPreference(system);
+        document.getElementById('measurement-label').textContent =
+          isMetric ? 'Metric' : 'Imperial';
+        // Show feedback
+        const info = document.querySelector('#measurement-section .setting-info');
+        info.innerHTML += '<p style="color:#00CC00;font-weight:bold;">✓ Updated to ' + system + '</p>';
+        setTimeout(() => location.reload(), 1500);
+      }
+      </script>
