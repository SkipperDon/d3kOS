+      <!-- Measurement System Section -->
+      <div class="settings-section" id="measurement-section">
+        <h2>Measurement System</h2>
+        <div class="setting-row">
+          <div class="setting-label">
+            <strong>Units</strong>
+            <p class="setting-description">Imperial (°F, PSI, gal, ft) or Metric (°C, bar, L, m)</p>
+          </div>
+          <div class="setting-control">
+            <label class="toggle-switch">
+              <input type="checkbox" id="measurement-toggle" onchange="handleMeasurementToggle()">
+              <span class="toggle-slider"></span>
+            </label>
+            <span id="measurement-label" class="toggle-label">Imperial</span>
+          </div>
+        </div>
+        <div class="setting-info">
+          <p><strong>Affects:</strong> Dashboard gauges, voice responses, navigation, weather, boatlog display</p>
