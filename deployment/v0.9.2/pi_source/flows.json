  {
    "id": "status-parse",
    "type": "function",
    "z": "system-tab",
    "name": "Parse Status",
    "func": "var status = msg.payload.trim();\nif (status === 'active') {\n    msg.payload = '<span style=\"color:green; font-weight:bold;\">\u25cf RUNNING</span>';\n} else if (status === 'inactive') {\n    msg.payload = '<span style=\"color:red; font-weight:bold;\">\u25cf STOPPED</span>';\n} else if (status === 'failed') {\n    msg.payload = '<span style=\"color:red; font-weight:bold;\">\u25cf FAILED</span>';\n} else {\n    msg.payload = '<span style=\"color:orange; font-weight:bold;\">\u25cf UNKNOWN</span>';\n}\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 510,
    "y": 380,
