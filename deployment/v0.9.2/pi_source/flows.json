    "id": "sys-exec-613294",
    "type": "exec",
    "z": "system-tab",
    "command": "vcgencmd measure_temp && free -m | grep Mem && df -h / | tail -1 && vcgencmd measure_temp",
    "name": "Get System Stats",
    "x": 300,
    "y": 600,
    "wires": [
      [
        "sys-parse-613294"
      ],
