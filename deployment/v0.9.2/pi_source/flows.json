  {
    "id": "signalk-router-108677",
    "type": "function",
    "z": "system-tab",
    "name": "Route Signal K Data",
    "func": "try {\n    const data = JSON.parse(msg.payload);\n    if (!data.updates) return null;\n\n    const msgs = [null, null, null, null];\n\n    data.updates.forEach(update => {\n        if (!update.values) return;\n\n        update.values.forEach(val => {\n            const path = val.path;\n            const value = val.value;\n\n            if (path && path.includes('revolutions')) {\n                msgs[0] = {payload: Math.round(value * 60 / (2 * Math.PI))};\n            }\n            else if (path && path.includes('oilPressure')) {\n                msgs[1] = {payload: Math.round(value / 6894.76)};\n            }\n            else if (path && path.includes('temperature')) {\n                msgs[2] = {payload: Math.round((value - 273.15) * 9/5 + 32)};\n            }\n            else if (path && path.includes('currentLevel')) {\n                msgs[3] = {payload: Math.round(value * 100)};\n            }\n        });\n    });\n\n    return msgs;\n} catch (e) {\n    return null;\n}",
    "outputs": 4,
    "x": 300,
    "y": 160,
    "wires": [
      [],
      [],
      [],
      []
    ]
  },
  {
    "id": "router-613294",
    "type": "function",
    "z": "system-tab",
    "name": "Route Signal K Data",
    "func": "try {\n    const data = JSON.parse(msg.payload);\n    if (!data.updates) return null;\n\n    // 9 outputs: RPM, Trim, Temp, Voltage, Oil, Fresh, Black, Fuel, Battery\n    const msgs = [null, null, null, null, null, null, null, null, null];\n\n    data.updates.forEach(update => {\n        if (!update.values) return;\n\n        update.values.forEach(val => {\n            const path = val.path;\n            const value = val.value;\n\n            // Engine gauges\n            if (path && path.includes('revolutions')) {\n                msgs[0] = {payload: Math.round(value * 60 / (2 * Math.PI))};\n            }\n            else if (path && path.includes('trimState')) {\n                msgs[1] = {payload: Math.round(value * 100)};\n            }\n            else if (path && path.includes('temperature')) {\n                msgs[2] = {payload: Math.round((value - 273.15) * 9/5 + 32)};\n            }\n            else if (path && path.includes('voltage')) {\n                msgs[3] = {payload: value.toFixed(1)};\n            }\n            else if (path && path.includes('oilPressure')) {\n                msgs[4] = {payload: Math.round(value / 6894.76)};\n            }\n            // Tank levels\n            else if (path && path.includes('tanks.freshWater') && path.includes('currentLevel')) {\n                msgs[5] = {payload: Math.round(value * 100)};\n            }\n            else if (path && path.includes('tanks.blackWater') && path.includes('currentLevel')) {\n                msgs[6] = {payload: Math.round(value * 100)};\n            }\n            else if (path && path.includes('tanks.fuel') && path.includes('currentLevel')) {\n                msgs[7] = {payload: Math.round(value * 100)};\n            }\n            else if (path && path.includes('batteries') && path.includes('capacity')) {\n                msgs[8] = {payload: Math.round(value.stateOfCharge * 100)};\n            }\n        });\n    });\n\n    return msgs;\n} catch (e) {\n    return null;\n}",
    "outputs": 9,
    "x": 980,
    "y": 140,
    "wires": [
      [],
      [],
      [],
      [],
      [],
      [],
      [],
      [],
      []
    ]
  },
