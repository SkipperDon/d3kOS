  {
    "id": "sys-parse-613294",
    "type": "function",
    "z": "system-tab",
    "name": "Parse System Stats",
    "func": "const output = msg.payload.trim().split(/\\r?\\n/);\nconst cpuMatch = output[0] ? output[0].match(/[\\d.]+/) : null;\nconst cpu = cpuMatch ? cpuMatch[0] + '\u00b0C' : 'N/A';\nconst memParts = output[1] ? output[1].trim().split(/\\s+/) : [];\nconst memUsed = parseInt(memParts[2]) || 0;\nconst memTotal = parseInt(memParts[1]) || 1;\nconst memPercent = Math.round((memUsed / memTotal) * 100);\nconst diskParts = output[2] ? output[2].trim().split(/\\s+/) : [];\nconst diskUsed = diskParts[4] || 'N/A';\nconst gpuMatch = output[3] ? output[3].match(/[\\d.]+/) : null;\nconst gpu = gpuMatch ? gpuMatch[0] + '\u00b0C' : cpu;\nreturn [\n    {payload: cpu},\n    {payload: memPercent + '%'},\n    {payload: diskUsed + ' used'},\n    {payload: gpu}\n];",
    "outputs": 4,
    "x": 500,
    "y": 600,
    "wires": [
      [],
      [],
      [],
      []
    ]
  },
